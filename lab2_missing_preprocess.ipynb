   "cell_type": "markdown",
   "id": "l2-title",
   "metadata": {},
   "source": [
    "# Лабораторная работа №2\n",
    "## Обработка пропусков, кодирование категориальных признаков, масштабирование\n",
    "\n",
    "Методичка: [LAB_TMO__MISSING](https://github.com/ugapanyuk/courses_current/wiki/LAB_TMO__MISSING).\n",
    "\n",
    "Датасет: Titanic через `seaborn.load_dataset(\"titanic\")`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "l2-imports",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "from pathlib import Path\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.impute import SimpleImputer\n",
    "from sklearn.preprocessing import OneHotEncoder, StandardScaler\n",
    "from sklearn.pipeline import Pipeline\n",
    "\n",
    "_root = Path.cwd()\n",
    "os.environ.setdefault(\"MPLCONFIGDIR\", str(_root / \"data\" / \"mplconfig\"))\n",
    "(_root / \"data\" / \"mplconfig\").mkdir(parents=True, exist_ok=True)\n",
    "_seaborn_home = _root / \"data\" / \"seaborn-cache\"\n",
    "_seaborn_home.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "plt.rcParams[\"figure.dpi\"] = 110\n",
    "%matplotlib inline\n",
    "\n",
    "df = sns.load_dataset(\"titanic\", data_home=str(_seaborn_home))\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "l2-select",
   "metadata": {},
   "outputs": [],
   "source": [
    "feature_cols = [\"pclass\", \"sex\", \"age\", \"sibsp\", \"parch\", \"fare\", \"embarked\"]\n",
    "X = df[feature_cols].copy()\n",
    "\n",
    "missing = X.isna().sum().sort_values(ascending=False)\n",
    "missing_pct = (100 * missing / len(X)).round(2)\n",
    "display(pd.DataFrame({\"пропусков\": missing, \"%\": missing_pct}).query(\"пропусков > 0\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "l2-pipeline",
   "metadata": {},
   "outputs": [],
   "source": [
    "numeric_features = [\"age\", \"sibsp\", \"parch\", \"fare\"]\n",
    "categorical_features = [\"pclass\", \"sex\", \"embarked\"]\n",
    "\n",
    "numeric_pipe = Pipeline([\n",
    "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
    "    (\"scaler\", StandardScaler()),\n",
    "])\n",
    "\n",
    "cat_pipe = Pipeline([\n",
    "    (\"imputer\", SimpleImputer(strategy=\"most_frequent\")),\n",
    "    (\"onehot\", OneHotEncoder(handle_unknown=\"ignore\", sparse_output=False)),\n",
    "])\n",
    "\n",
    "prep = ColumnTransformer([\n",
    "    (\"num\", numeric_pipe, numeric_features),\n",
    "    (\"cat\", cat_pipe, categorical_features),\n",
    "])\n",
    "\n",
    "X_prep = prep.fit_transform(X)\n",
    "cols = prep.get_feature_names_out()\n",
    "X_prep_df = pd.DataFrame(X_prep, columns=cols)\n",
    "print(\"shape:\", X_prep_df.shape)\n",
    "display(X_prep_df.head())"
   ]
  }
 ],
